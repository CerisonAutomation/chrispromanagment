{
  "framework": "nextjs",
  "regions": ["fra1"],
  "functions": {
    "src/app/api/qstash/worker/route.ts": { "maxDuration": 300 },
    "src/app/api/guesty/sync/route.ts": { "maxDuration": 60 },
    "src/app/api/guesty/webhook/route.ts": { "maxDuration": 30 },
    "src/app/api/guesty/listings/route.ts": { "maxDuration": 60 },
    "src/app/api/guesty/reservations/route.ts": { "maxDuration": 60 },
    "src/app/api/guesty/guests/route.ts": { "maxDuration": 30 },
    "src/app/api/guesty/calendar/route.ts": { "maxDuration": 30 },
    "src/app/api/guesty/quote/route.ts": { "maxDuration": 30 },
    "src/app/api/ai/route.ts": { "maxDuration": 60 },
    "src/app/api/cron/sync-listings/route.ts": { "maxDuration": 300 },
    "src/app/api/cron/sync-reservations/route.ts": { "maxDuration": 300 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Cache-Control", "value": "no-store, no-cache" },
        { "key": "X-Robots-Tag", "value": "noindex" }
      ]
    }
  ],
  "crons": [
    { "path": "/api/cron/sync-listings", "schedule": "0 3 * * *" },
    { "path": "/api/cron/sync-reservations", "schedule": "0 4 * * *" }
  ]
}
