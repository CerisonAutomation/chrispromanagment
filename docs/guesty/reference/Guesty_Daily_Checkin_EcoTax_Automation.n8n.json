    {
      "parameters": {
        "jsCode": "// Compute Eco-Tax based on numAdults and checkIn date\nconst item = $input.first();\nconst reservation = $('Guesty – Fetch Reservation').first().json;\n\nconst numAdults = parseInt(item.json.numAdults) || parseInt(reservation.guestsCount) || 0;\nconst checkIn = item.json.checkIn || reservation.checkIn;\nconst checkOut = reservation.checkOut;\nconst reservationId = item.json.reservationId;\nconst guestName = item.json.guestName || reservation.guest?.fullName || '';\nconst guestEmail = reservation.guest?.email || item.json.guestEmail || '';\n\n// Eco-tax rate: €0.50 per adult per night\nconst ECO_TAX_PER_ADULT_PER_NIGHT = 0.50;\n\nlet nights = 0;\nif (checkIn && checkOut) {\n  const msPerDay = 24 * 60 * 60 * 1000;\n  nights = Math.round((new Date(checkOut) - new Date(checkIn)) / msPerDay);\n}\n\nconst ecoTaxAmount = numAdults * nights * ECO_TAX_PER_ADULT_PER_NIGHT;\n\nreturn [{\n  json: {\n    reservationId,\n    guestName,\n    guestEmail,\n    checkIn,\n    checkOut,\n    numAdults,\n    nights,\n    ecoTaxAmount,\n    ecoTaxFormatted: `€${ecoTaxAmount.toFixed(2)}`,\n    accessToken: $('Guesty – Get OAuth Token').first().json.access_token\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
