    {
      "parameters": {
        "jsCode": "// Parse Guesty reservation email from Gmail Trigger\nconst items = [];\n\nfor (const item of $input.all()) {\n  const subject = item.json.subject || '';\n  const body = item.json.text || item.json.snippet || '';\n  const emailId = item.json.id || '';\n  const threadId = item.json.threadId || '';\n\n  // Extract reservation ID from subject or body\n  // Guesty emails typically include confirmation codes like HXXXXXXXXX or numeric IDs\n  const reservationIdMatch = body.match(/reservation[\\s#:]+([A-Z0-9\\-]{6,})/i)\n    || subject.match(/([A-Z]{1,3}[0-9]{6,})/)\n    || body.match(/confirmation[\\s#:]+([A-Z0-9\\-]{6,})/i);\n\n  const reservationId = reservationIdMatch ? reservationIdMatch[1].trim() : null;\n\n  // Extract guest name\n  const guestMatch = body.match(/guest[\\s:]+([A-Za-z ]{2,40})/i)\n    || body.match(/name[\\s:]+([A-Za-z ]{2,40})/i);\n  const guestName = guestMatch ? guestMatch[1].trim() : 'Guest';\n\n  // Extract check-in date\n  const checkInMatch = body.match(/check[\\s-]?in[\\s:]+([\\d]{1,2}[\\s\\/\\-][A-Za-z\\d]{1,9}[\\s\\/\\-][\\d]{2,4})/i);\n  const checkIn = checkInMatch ? checkInMatch[1].trim() : null;\n\n  // Extract number of adults/guests\n  const adultsMatch = body.match(/(\\d+)\\s*(adult|guest|person)/i);\n  const numAdults = adultsMatch ? parseInt(adultsMatch[1]) : 1;\n\n  items.push({\n    json: {\n      emailId,\n      threadId,\n      subject,\n      reservationId,\n      guestName,\n      checkIn,\n      numAdults,\n      rawBody: body.substring(0, 500)\n    }\n  });\n}\n\nreturn items;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
