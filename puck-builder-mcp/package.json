{
  "name": "puck-builder-mcp",
  "version": "7.1.0",
  "description": "Ω⁷ Puck Builder MCP v7.1 — 40 blocks, 14 tools, 5 resources, 4 prompts. AI-universal, persistent, crash-safe.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "puck-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
