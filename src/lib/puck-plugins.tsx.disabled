  <div className="puck-preview-custom bg-neutral-50">{children}</div>
);

// =============================================================================
// FIELD TRANSFORMS (P0 FIX #9)
// =============================================================================

/**
 * P0 FIX #9: Field transform helpers
 */

// Transform to slugify text
export const slugifyTransform = (params: { value: string; onChange: (v: string) => void }) => {
  const slug = params.value
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)/g, "");
  params.onChange(slug);
};

// Transform to uppercase
export const uppercaseTransform = (params: { value: string; onChange: (v: string) => void }) => {
  params.onChange(params.value.toUpperCase());
};

// Transform for SEO title
export const seoTitleTransform = (params: { value: string; onChange: (v: string) => void }) => {
  if (params.value.length > 60) {
    params.onChange(params.value.substring(0, 57) + "...");
  }
};

// =============================================================================
// PLUGIN REGISTRY
// =============================================================================

export const builtInPlugins: Plugin[] = [
  createAIAssistantPlugin(),
  createContentOptimizerPlugin(),
  createAnalyticsPlugin(),
];

/**
 * Create a plugin manager for combining plugins
 */
export class PluginManager<UserConfig extends Config = Config> {
  private plugins: Plugin<UserConfig>[] = [];
  
  add(plugin: Plugin<UserConfig>): this {
    this.plugins.push(plugin);
    return this;
  }
  
  remove(name: string): this {
    this.plugins = this.plugins.filter((p) => p.name !== name);
    return this;
  }
  
  getPlugins(): Plugin<UserConfig>[] {
    return [...this.plugins];
  }
  
  getMergedOverrides(): Partial<Overrides> {
    return mergePlugins(this.plugins).overrides;
  }
  
  getMergedFieldTransforms(): FieldTransforms {
    return mergePlugins(this.plugins).fieldTransforms;
  }
}

// =============================================================================
// DEFAULT EXPORTS
// =============================================================================

export const PuckPlugins = {
  createPlugin,
  mergePlugins,
  createAIAssistantPlugin,
  createContentOptimizerPlugin,
  createAnalyticsPlugin,
  createThemePlugin,
  createConditionalFieldsPlugin,
  createOverride,
  customHeaderOverride,
  customFieldsOverride,
  customPreviewOverride,
  PluginManager,
  builtInPlugins,
};

export default PuckPlugins;
