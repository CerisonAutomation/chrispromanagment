// =============================================================================
// OVERRIDES SYSTEM (P0 FIX #5)
// =============================================================================

/**
 * P0 FIX #5: Helper to create override render functions
 */
export function createOverride<K extends keyof Overrides>(
  key: K,
  render: NonNullable<Overrides>[K] extends RenderFunc<infer P> 
    ? (props: P) => ReactElement 
    : never
): Partial<Overrides> {
  return { [key]: render } as Partial<Overrides>;
}

/**
 * P0 FIX #5: Pre-built override components
 */

// Header override with custom branding
export const customHeaderOverride: Overrides["header"] = ({ children, actions }) => (
  <div className="flex items-center justify-between px-4 py-2 bg-white border-b">
    <div className="flex items-center">{children}</div>
    <div className="flex items-center gap-2">{actions}</div>
  </div>
);

