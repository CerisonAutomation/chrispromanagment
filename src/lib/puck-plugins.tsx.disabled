// =============================================================================
// BUILT-IN PLUGIN: THEME CUSTOMIZATION
// =============================================================================

type ThemePluginConfig = {
  primaryColor?: string;
  accentColor?: string;
};

/**
 * Theme customization plugin demonstrating overrides
 */
export function createThemePlugin(config: ThemePluginConfig = {}): Plugin {
  const { primaryColor = "#6366f1", accentColor = "#8b5cf6" } = config;
  
  return {
    name: "theme",
    label: "Theme",
    
    overrides: {
      // Custom header styling
      header: ({ children, actions }) => (
        <div 
          className="puck-header-custom"
          style={{ background: `linear-gradient(135deg, ${primaryColor}, ${accentColor})` }}
        >
          <div className="flex-1">{children}</div>
          <div className="flex items-center">{actions}</div>
        </div>
      ),
      
      // Custom field styling
      fieldLabel: ({ children, label }) => (
        <div className="puck-field-label-custom">
          {children || label}
        </div>
      ),
    },
  };
}

