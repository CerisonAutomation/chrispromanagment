// =============================================================================
// CANONICAL PUCK PLUGINS - Complete P0 Implementation
// Based on puck-main patterns with full type safety
// =============================================================================

import React, {createContext, ReactElement, useCallback, useContext, useState} from "react";
import type {
  Config,
  FieldProps,
  FieldTransforms,
  Overrides,
  Plugin,
  RenderFunc,
  TextField,
} from "./canonical-puck-types";
import {Sparkles, Wand2, Zap} from "lucide-react";

// =============================================================================
// PLUGIN SYSTEM (P0 FIX #4)
// =============================================================================

/**
 * P0 FIX #4: Complete plugin architecture with render functions
 * 
 * Plugin interface matches puck-main exactly:
 * - name, label, icon for identification
 * - render for custom UI panels
 * - overrides for render function customization
 * - fieldTransforms for field processing
 */
export function createPlugin<UserConfig extends Config = Config>(
  plugin: Plugin<UserConfig>
): Plugin<UserConfig> {
  return plugin;
}

/**
 * Merge multiple plugins into a single overrides object
 */
export function mergePlugins<UserConfig extends Config = Config>(
  plugins: Plugin<UserConfig>[]
): {
  overrides: Partial<Overrides>;
  fieldTransforms: FieldTransforms;
} {
  return plugins.reduce(
    (acc, plugin) => ({
      overrides: { ...acc.overrides, ...plugin.overrides },
      fieldTransforms: { ...acc.fieldTransforms, ...plugin.fieldTransforms },
    }),
    {
      overrides: {},
      fieldTransforms: {},
    } as {
      overrides: Partial<Overrides>;
      fieldTransforms: FieldTransforms;
    }
  );
}

// =============================================================================
// BUILT-IN PLUGIN: AI ASSISTANT
// =============================================================================

type AIFieldContextType = {
  enabled: boolean;
  model: string;
  apiKey?: string;
};

const AIFieldContext = createContext<AIFieldContextType>({
  enabled: false,
  model: "gpt-4o",
});

export const AIFieldProvider = AIFieldContext.Provider;

export function useAIField() {
  return useContext(AIFieldContext);
}

// AI Generate Button Component
function AIGenerateButton({
  fieldName,
  onGenerate,
  disabled = false,
}: {
  fieldName: string;
  onGenerate: (value: string) => void;
  disabled?: boolean;
}) {
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState<string | null>(null);
  const aiContext = useAIField();

  const handleGenerate = useCallback(async () => {
    if (!aiContext.enabled) {
      setError("AI not enabled");
      return;
    }

    setLoading(true);
    setError(null);

    try {
      const response = await fetch("/api/ai/generate", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          field: fieldName,
          model: aiContext.model,
        }),
      });

      if (!response.ok) throw new Error("Generation failed");

      const data = await response.json();
      onGenerate(data.result);
    } catch (err) {
      setError(err instanceof Error ? err.message : "Failed");
    } finally {
      setLoading(false);
    }
  }, [aiContext, fieldName, onGenerate]);

  return (
    <div className="flex items-center gap-2">
      <button
        type="button"
        onClick={handleGenerate}
        disabled={loading || disabled || !aiContext.enabled}
        className="puck-ai-btn flex items-center gap-1.5 px-2 py-1 text-xs bg-purple-500/20 text-purple-400 rounded hover:bg-purple-500/30 transition-colors disabled:opacity-50"
      >
        {loading ? (
          <Sparkles className="h-3.5 w-3.5 animate-spin" />
        ) : (
          <Wand2 className="h-3.5 w-3.5" />
        )}
        <span>Generate</span>
      </button>
      {error && <span className="text-red-500 text-xs">{error}</span>}
    </div>
  );
}

/**
 * P0 FIX #4: AI Text Field Plugin Component
 */
function AITextFieldComponent(props: FieldProps<TextField, string>) {
  const { field, value, onChange, readOnly } = props;
  
  return (
    <div className="puck-ai-text-field">
      <div className="puck-field-header flex items-center justify-between mb-2">
        <label className="text-sm font-medium text-neutral-700 dark:text-neutral-300">
          {field.label || "Text"}
        </label>
        {!readOnly && (
          <AIGenerateButton
            fieldName={field.label || "text"}
            onGenerate={onChange ?? (() => {})}
          />
        )}
      </div>
      <input
        type="text"
        value={value || ""}
        onChange={(e) => onChange?.(e.target.value)}
        placeholder={field.placeholder}
        className="puck-input w-full px-3 py-2 border rounded-md bg-white dark:bg-neutral-800 border-neutral-300 dark:border-neutral-700"
        readOnly={readOnly}
      />
    </div>
  );
}

/**
 * P0 FIX #4: AI Textarea Field Plugin Component
 */
function AITextareaFieldComponent(props: FieldProps<any, string>) {
  const { field, value, onChange, readOnly } = props;
  
  return (
    <div className="puck-ai-textarea-field">
      <div className="puck-field-header flex items-center justify-between mb-2">
        <label className="text-sm font-medium text-neutral-700 dark:text-neutral-300">
          {field.label || "Text"}
        </label>
        {!readOnly && (
          <AIGenerateButton
            fieldName={field.label || "textarea"}
            onGenerate={onChange ?? (() => {})}
          />
        )}
      </div>
      <textarea
        value={value || ""}
        onChange={(e) => onChange?.(e.target.value)}
        placeholder={field.placeholder}
        className="puck-textarea w-full px-3 py-2 border rounded-md bg-white dark:bg-neutral-800 border-neutral-300 dark:border-neutral-700"
        rows={4}
        readOnly={readOnly}
      />
    </div>
  );
}

/**
 * P0 FIX #4: AI Assistant Plugin
 */
export function createAIAssistantPlugin(): Plugin {
  return {
    name: "ai-assistant",
    label: "AI Assistant",
    icon: <Sparkles className="h-4 w-4" />,
    
    overrides: {
      fieldTypes: {
        text: AITextFieldComponent as any,
        textarea: AITextareaFieldComponent as any,
      },
    },
    
    fieldTransforms: {
      text: (params) => {
        // Transform text field values
        return params.value;
      },
    },
  };
}

