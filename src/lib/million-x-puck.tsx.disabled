  PuckAction,
  Render as PuckRender,
} from "@puckeditor/core";
import {AIFieldProvider} from "./puck-plugins";

// =============================================================================
// 1. ADVANCED USEPUCK HOOK - Complete API Surface
// =============================================================================

interface PuckContextValue {
  data: Data;
  dispatch: (action: PuckAction) => void;
  selectedItem: { id: string; type: string; zone: string } | null;
  setSelectedItem: (item: { id: string; type: string; zone: string } | null) => void;
  breadcrumbs: Array<{ id: string; type: string; label: string }>;
  history: {
    undo: () => void;
    redo: () => void;
    canUndo: boolean;
    canRedo: boolean;
    past: Data[];
    future: Data[];
    jumpTo: (index: number) => void;
  };
  collaborators: Array<{ id: string; name: string; color: string; cursor?: { x: number; y: number } }>;
  resolveData: (id: string) => Promise<void>;
  resolveFields: (id: string) => Promise<Record<string, Field>>;
  resolvePermissions: (id: string) => Promise<Record<string, boolean>>;
  ui: {
    leftSidebarOpen: boolean;
    rightSidebarOpen: boolean;
    previewMode: "edit" | "preview" | "live";
    viewport: { width: number; height: number };
    zoom: number;
    setLeftSidebarOpen: (open: boolean) => void;
    setRightSidebarOpen: (open: boolean) => void;
    setPreviewMode: (mode: "edit" | "preview" | "live") => void;
    setViewport: (viewport: { width: number; height: number }) => void;
    setZoom: (zoom: number) => void;
  };
  permissions: {
    canEdit: boolean;
    canPublish: boolean;
    canDelete: boolean;
    canCreate: boolean;
    canManageSettings: boolean;
  };
  insertComponent: (type: string, zone: string, index: number) => void;
  duplicateComponent: (id: string) => void;
  deleteComponent: (id: string) => void;
  moveComponent: (id: string, fromZone: string, toZone: string, fromIndex: number, toIndex: number) => void;
  updateComponent: (id: string, props: Record<string, any>) => void;
  autoSave: {
    enabled: boolean;
    interval: number;
    lastSaved: Date | null;
    isSaving: boolean;
    error: Error | null;
  };
  validation: {
    errors: Array<{ id: string; field: string; message: string }>;
    warnings: Array<{ id: string; field: string; message: string }>;
    validate: () => boolean;
  };
}

const PuckContext = React.createContext<PuckContextValue | null>(null);

function usePuck(): PuckContextValue {
  const context = useContext(PuckContext);
  if (!context) {
    throw new Error("usePuck must be used within a MillionXPuckProvider");
  }
  return context;
}

// =============================================================================
// 2. ADVANCED PLUGIN SYSTEM
// =============================================================================

type PluginPosition = "left" | "right" | "bottom" | "floating";

interface MillionXPlugin extends Plugin {
  id: string;
  name: string;
  description?: string;
  icon?: React.ReactNode;
  position?: PluginPosition;
  render: () => React.ReactElement;
  onInit?: (context: PuckContextValue) => void;
  onDestroy?: () => void;
  shortcuts?: Array<{ key: string; action: () => void; description: string }>;
}

// Plugin Components
function OutlinePanel() {
  const { data, selectedItem, setSelectedItem } = usePuck();
  return (
    <div className="puck-outline-panel">
      <h3>Outline</h3>
      <ul>
        {data.content.map((item) => (
          <li 
            key={item.props.id} 
            className={selectedItem?.id === item.props.id ? "selected" : ""}
            onClick={() => setSelectedItem({ id: item.props.id, type: item.type, zone: "root" })}
          >
            {item.type}
          </li>
        ))}
      </ul>
    </div>
  );
}

function FieldsPanel() {
  const { selectedItem, data } = usePuck();
  if (!selectedItem) return <div>Select a component</div>;
  
  const component = data.content.find(c => c.props.id === selectedItem.id);
  if (!component) return <div>Component not found</div>;
  
  return (
    <div className="puck-fields-panel">
      <h3>Fields - {component.type}</h3>
    </div>
  );
}

function ComponentsPanel() {
  return (
    <div className="puck-components-panel">
      <h3>Components</h3>
      <div className="component-grid">
      </div>
    </div>
  );
}

function HistoryPanel() {
  const { history } = usePuck();
  return (
    <div className="puck-history-panel">
      <h3>History</h3>
      <button onClick={history.undo} disabled={!history.canUndo}>Undo</button>
      <button onClick={history.redo} disabled={!history.canRedo}>Redo</button>
      <ul>
        {history.past.map((_, i) => (
          <li key={i}>Change {i + 1}</li>
        ))}
      </ul>
    </div>
  );
}

function AIPanel() {
  const [prompt, setPrompt] = useState("");
  const [generating, setGenerating] = useState(false);
  
  const handleGenerate = async () => {
    setGenerating(true);
    try {
      const response = await fetch("/api/ai/build-page", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ prompt }),
      });
      const data = await response.json();
    } finally {
      setGenerating(false);
    }
  };
  
  return (
    <div className="puck-ai-panel">
      <h3>AI Assistant</h3>
      <textarea 
        value={prompt} 
        onChange={(e) => setPrompt(e.target.value)}
        placeholder="Describe what you want to create..."
      />
      <button onClick={handleGenerate} disabled={generating}>
        {generating ? "Generating..." : "Generate"}
      </button>
    </div>
  );
}

// Plugin Factory Functions
function createOutlinePlugin(): MillionXPlugin {
  return {
    id: "outline",
    name: "Outline",
    position: "left",
    render: () => React.createElement(OutlinePanel),
  };
}

function createFieldsPlugin(): MillionXPlugin {
  return {
    id: "fields",
    name: "Fields",
    position: "right",
    render: () => React.createElement(FieldsPanel),
  };
}

function createComponentsPlugin(): MillionXPlugin {
  return {
    id: "components",
    name: "Components",
    position: "left",
    render: () => React.createElement(ComponentsPanel),
  };
}

function createHistoryPlugin(): MillionXPlugin {
  return {
    id: "history",
    name: "History",
    position: "right",
    render: () => React.createElement(HistoryPanel),
  };
}

function createAIPanelPlugin(): MillionXPlugin {
  return {
    id: "ai-panel",
    name: "AI Assistant",
    position: "right",
    render: () => React.createElement(AIPanel),
  };
}

