interface MillionXOverrides extends Partial<Overrides> {
  header?: (props: { 
    children: ReactNode; 
    actions: ReactNode;
    title?: string;
    breadcrumbs?: Array<{ label: string; path: string }>;
  }) => React.ReactElement;
  canvas?: (props: {
    children: ReactNode;
    viewport: { width: number; height: number };
    zoom: number;
  }) => React.ReactElement;
  componentItem?: (props: {
    children: ReactNode;
    name: string;
    icon?: ReactNode;
    description?: string;
  }) => React.ReactElement;
  field?: (props: {
    children: ReactNode;
    label: string;
    error?: string;
    warning?: string;
  }) => React.ReactElement;
  modal?: (props: {
    children: ReactNode;
    title: string;
    onClose: () => void;
  }) => React.ReactElement;
  toast?: (props: {
    message: string;
    type: "success" | "error" | "warning" | "info";
    onClose: () => void;
  }) => React.ReactElement;
}

function createDefaultOverrides(): Partial<MillionXOverrides> {
  return {
    header: ({ children, actions, title }) => (
      <div className="millionx-header">
        <div className="header-left">
          {title && <h1 className="header-title">{title}</h1>}
        </div>
        <div className="header-center">{children}</div>
        <div className="header-actions">{actions}</div>
      </div>
    ),
    canvas: ({ children, viewport }) => (
      <div 
        className="millionx-canvas"
        style={{ 
          width: typeof viewport.width === "number" ? `${viewport.width}px` : viewport.width,
          height: typeof viewport.height === "number" ? `${viewport.height}px` : viewport.height,
        }}
      >
        {children}
      </div>
    ),
    toast: ({ message, type, onClose }) => (
      <div className={`millionx-toast millionx-toast-${type}`} onClick={onClose}>
        {message}
      </div>
    ),
  };
}

// =============================================================================
// 4. RESOLVEDATA PATTERN
// =============================================================================

interface ResolveDataResolver {
  (
    data: any,
    params: {
      changed: Record<string, boolean | undefined>;
      lastData: any;
      trigger: "insert" | "replace" | "load" | "force" | "move";
      metadata: Record<string, any>;
    }
  ): Promise<{ props?: Record<string, any>; readOnly?: Record<string, boolean> }> | 
     { props?: Record<string, any>; readOnly?: Record<string, boolean> };
}

interface ResolveFieldsResolver {
  (
    data: any,
    params: {
      changed: Record<string, boolean | undefined>;
      fields: Record<string, Field>;
      lastFields: Record<string, Field>;
      lastData: any;
    }
  ): Promise<Record<string, Field>> | Record<string, Field>;
}

interface ResolvePermissionsResolver {
  (
    data: any,
    params: {
      changed: Record<string, boolean | undefined>;
      lastPermissions: Record<string, boolean>;
      permissions: Record<string, boolean>;
    }
  ): Promise<Record<string, boolean>> | Record<string, boolean>;
}

interface ComponentResolvers {
  resolveData?: ResolveDataResolver;
  resolveFields?: ResolveFieldsResolver;
  resolvePermissions?: ResolvePermissionsResolver;
}

function withResolvers(
  config: Config,
  resolvers: Record<string, ComponentResolvers>
): Config {
  return {
    ...config,
    components: Object.fromEntries(
      Object.entries(config.components).map(([key, componentConfig]) => {
        const resolver = resolvers[key];
        if (!resolver) return [key, componentConfig];
        
        return [key, {
          ...componentConfig,
          resolveData: resolver.resolveData,
          resolveFields: resolver.resolveFields,
          resolvePermissions: resolver.resolvePermissions,
        }];
      })
    ),
  };
}

// =============================================================================
// 5. ONACTION SYSTEM
// =============================================================================

type ActionType = 
  | "insert" | "duplicate" | "move" | "replace" | "replaceRoot"
  | "remove" | "reorder" | "set" | "setData" | "setUi"
  | "registerZone" | "unregisterZone";

interface ActionContext {
  action: PuckAction;
  state: AppState;
  prevState: AppState;
  timestamp: number;
  user: { id: string; name: string; role: string };
  session: { id: string; startTime: Date };
}

type ActionInterceptor = (context: ActionContext) => void | boolean | Promise<void | boolean>;
type ActionTransformer = (context: ActionContext) => PuckAction | Promise<PuckAction>;

class ActionPipeline {
  private interceptors: ActionInterceptor[] = [];
  private transformers: ActionTransformer[] = [];
  private subscribers: Array<(context: ActionContext) => void> = [];
  
  addInterceptor(interceptor: ActionInterceptor) {
    this.interceptors.push(interceptor);
  }
  
  addTransformer(transformer: ActionTransformer) {
    this.transformers.push(transformer);
  }
  
  subscribe(callback: (context: ActionContext) => void) {
    this.subscribers.push(callback);
    return () => {
      const index = this.subscribers.indexOf(callback);
      if (index > -1) this.subscribers.splice(index, 1);
    };
  }
  
  async process(action: PuckAction, state: AppState, prevState: AppState): Promise<PuckAction | null> {
    const context: ActionContext = {
      action,
      state,
      prevState,
      timestamp: Date.now(),
      user: this.getCurrentUser(),
      session: this.getCurrentSession(),
    };
    
    for (const interceptor of this.interceptors) {
      const result = await interceptor(context);
      if (result === false) {
        console.log("Action cancelled by interceptor");
        return null;
      }
    }
    
    let transformedAction = action;
    for (const transformer of this.transformers) {
      transformedAction = await transformer({ ...context, action: transformedAction });
    }
    
    this.subscribers.forEach(cb => cb({ ...context, action: transformedAction }));
    
    return transformedAction;
  }
  
  private getCurrentUser() {
    return { id: "user-1", name: "Admin", role: "admin" };
  }
  
  private getCurrentSession() {
    return { id: "session-1", startTime: new Date() };
  }
}

function createAnalyticsInterceptor(
  tracker: (event: string, data: any) => void
): ActionInterceptor {
  return (context) => {
    tracker("puck_action", {
      type: (context.action as any).type,
      timestamp: context.timestamp,
      user: context.user.id,
    });
  };
}

function createAuditInterceptor(apiEndpoint: string): ActionInterceptor {
  return async (context) => {
    try {
      await fetch(apiEndpoint, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          action: (context.action as any).type,
          timestamp: context.timestamp,
          user: context.user,
          changes: detectChanges(context.prevState.data, context.state.data),
        }),
      });
    } catch (err) {
      console.error("Audit log failed:", err);
    }
  };
}

function createValidationInterceptor(
  validators: Array<(state: AppState) => { valid: boolean; errors: string[] }>
): ActionInterceptor {
  return (context) => {
    for (const validator of validators) {
      const result = validator(context.state);
      if (!result.valid) {
        console.error("Validation failed:", result.errors);
        return false;
      }
    }
  };
}

function detectChanges(prev: Data, current: Data): any {
  const changes: any = {};
  if (prev.content.length !== current.content.length) {
    changes.componentCount = { from: prev.content.length, to: current.content.length };
  }
  return changes;
}

// =============================================================================
// 6. REAL-TIME COLLABORATION
// =============================================================================

interface CollaborationSession {
  id: string;
  users: Array<{
    id: string;
    name: string;
    color: string;
    cursor?: { x: number; y: number; componentId?: string };
    selection?: string[];
  }>;
  awareness: Map<string, any>;
}

function useCollaboration(sessionId: string) {
  const [session, setSession] = useState<CollaborationSession | null>(null);
  const [connected, setConnected] = useState(false);
  const wsRef = useRef<WebSocket | null>(null);
  
  const handleCollaborationMessage = (message: any) => {
    switch (message.type) {
      case "user_joined":
      case "user_left":
      case "cursor_update":
      case "selection_update":
      case "state_sync":
        break;
    }
  };
  
  useEffect(() => {
    const ws = new WebSocket(`wss://collab.example.com/${sessionId}`);
    wsRef.current = ws;
    
    ws.onopen = () => setConnected(true);
    ws.onclose = () => setConnected(false);
    ws.onmessage = (event) => {
      const message = JSON.parse(event.data);
      handleCollaborationMessage(message);
    };
    
    return () => ws.close();
  }, [sessionId]);
  
  const updateCursor = (x: number, y: number, componentId?: string) => {
    wsRef.current?.send(JSON.stringify({
      type: "cursor_update",
      data: { x, y, componentId },
    }));
  };
  
  const updateSelection = (componentIds: string[]) => {
    wsRef.current?.send(JSON.stringify({
      type: "selection_update",
      data: { componentIds },
    }));
  };
  
  return {
    session,
    connected,
    updateCursor,
    updateSelection,
  };
}

// =============================================================================
// 7. AUTO-SAVE WITH CONFLICT RESOLUTION
// =============================================================================

interface AutoSaveState {
  status: "idle" | "saving" | "saved" | "error" | "conflict";
  lastSaved: Date | null;
  error: Error | null;
  pendingChanges: number;
  serverVersion: number;
  localVersion: number;
}

function useAutoSave(
  data: Data,
  saveFn: (data: Data, version: number) => Promise<{ success: boolean; version: number }>,
  options: { interval?: number; onConflict?: (local: Data, server: Data) => Data } = {}
) {
  const { interval = 5000, onConflict } = options;
  const [state, setState] = useState<AutoSaveState>({
    status: "idle",
    lastSaved: null,
    error: null,
    pendingChanges: 0,
    serverVersion: 0,
    localVersion: 0,
  });
  
  const dataRef = useRef(data);
  dataRef.current = data;
  
  useEffect(() => {
    const timer = setInterval(async () => {
      if (state.status === "saving") return;
      
      setState(s => ({ ...s, status: "saving" }));
      
      try {
        const result = await saveFn(dataRef.current, state.localVersion);
        
        if (result.success) {
          setState(s => ({
            ...s,
            status: "saved",
            lastSaved: new Date(),
            serverVersion: result.version,
            localVersion: result.version,
            pendingChanges: 0,
          }));
        } else {
          setState(s => ({ ...s, status: "conflict" }));
        }
      } catch (error) {
        setState(s => ({
          ...s,
          status: "error",
          error: error as Error,
        }));
      }
    }, interval);
    
    return () => clearInterval(timer);
  }, [interval, saveFn, state.localVersion, state.status]);
  
  const forceSave = async () => {
    setState(s => ({ ...s, status: "saving" }));
    try {
      const result = await saveFn(dataRef.current, state.localVersion);
      setState(s => ({
        ...s,
        status: result.success ? "saved" : "conflict",
        lastSaved: new Date(),
      }));
    } catch (error) {
      setState(s => ({ ...s, status: "error", error: error as Error }));
    }
  };
  
  return { ...state, forceSave };
}

// =============================================================================
// 8. VALIDATION SYSTEM
// =============================================================================

interface ValidationRule {
  id: string;
  name: string;
  validate: (data: Data) => { valid: boolean; errors: ValidationError[] };
}

interface ValidationError {
  componentId: string;
  field?: string;
  message: string;
  severity: "error" | "warning" | "info";
  autoFix?: () => void;
}

function createRequiredFieldValidator(fieldPath: string): ValidationRule {
  return {
    id: `required-${fieldPath}`,
    name: `Required Field: ${fieldPath}`,
    validate: (data) => {
      const errors: ValidationError[] = [];
      data.content.forEach((component) => {
        const value = fieldPath.split(".").reduce((obj: any, key) => obj?.[key], component.props);
        if (!value || (typeof value === "string" && value.trim() === "")) {
          errors.push({
            componentId: component.props.id,
            field: fieldPath,
            message: `${fieldPath} is required`,
            severity: "error",
          });
        }
      });
      return { valid: errors.length === 0, errors };
    },
  };
}

function createLinkValidator(): ValidationRule {
  return {
    id: "valid-links",
    name: "Valid Links",
    validate: (data) => {
      const errors: ValidationError[] = [];
      return { valid: errors.length === 0, errors };
    },
  };
}

function createImageValidator(): ValidationRule {
  return {
    id: "valid-images",
    name: "Valid Images",
    validate: (data) => {
      const errors: ValidationError[] = [];
      return { valid: errors.length === 0, errors };
    },
  };
}

// =============================================================================
// 9. MILLION-X PUCK COMPONENT
// =============================================================================

interface MillionXPuckProps {
  config: Config;
  data: Data;
  onChange?: (data: Data) => void;
  onPublish?: (data: Data) => void;
  plugins?: MillionXPlugin[];
  pluginPositions?: Partial<Record<PluginPosition, boolean>>;
  overrides?: Partial<MillionXOverrides>;
  resolvers?: Record<string, ComponentResolvers>;
  actionPipeline?: ActionPipeline;
  interceptors?: ActionInterceptor[];
  transformers?: ActionTransformer[];
  collaboration?: { enabled: boolean; sessionId: string };
  autoSave?: { enabled: boolean; interval?: number; saveFn?: (data: Data, version: number) => Promise<{ success: boolean; version: number }> };
  validators?: ValidationRule[];
  ai?: { enabled: boolean; model?: string };
  preview?: { enabled: boolean; shareable?: boolean };
  header?: { title?: string; breadcrumbs?: Array<{ label: string; path: string }> };
  viewports?: Array<{ width: number; height: number; label: string }>;
  permissions?: { canEdit?: boolean; canPublish?: boolean; canDelete?: boolean };
}

function MillionXPuck({
  config,
  data: initialData,
  onChange,
  onPublish,
  plugins = [],
  pluginPositions = { left: true, right: true },
  overrides = {},
  resolvers = {},
  actionPipeline = new ActionPipeline(),
  interceptors = [],
  transformers = [],
  collaboration,
  autoSave,
  validators = [],
  ai = { enabled: true },
  preview = { enabled: true },
  header,
  viewports = [
    { width: 1920, height: 1080, label: "Desktop" },
    { width: 768, height: 1024, label: "Tablet" },
    { width: 375, height: 667, label: "Mobile" },
  ],
  permissions = { canEdit: true, canPublish: true, canDelete: true },
}: MillionXPuckProps) {
  const [data, setData] = useState<Data>(initialData);
  const [selectedItem, setSelectedItem] = useState<{ id: string; type: string; zone: string } | null>(null);
  const [history, setHistory] = useState<{ past: Data[]; future: Data[] }>({ past: [], future: [] });
  const [ui, setUi] = useState({
    leftSidebarOpen: pluginPositions.left ?? true,
    rightSidebarOpen: pluginPositions.right ?? true,
    previewMode: "edit" as "edit" | "preview" | "live",
    viewport: viewports[0],
    zoom: 1,
  });
  
  const dataRef = useRef(data);
  dataRef.current = data;
  
  useEffect(() => {
    interceptors.forEach(i => actionPipeline.addInterceptor(i));
    transformers.forEach(t => actionPipeline.addTransformer(t));
  }, [actionPipeline, interceptors, transformers]);
  
  const enhancedConfig = withResolvers(config, resolvers);
  
  const contextValue: PuckContextValue = {
    data,
    dispatch: async (action) => {
      const processedAction = await actionPipeline.process(action, { data, ui: {} as any }, { data: dataRef.current, ui: {} as any });
      if (!processedAction) return;
    },
    selectedItem,
    setSelectedItem,
    breadcrumbs: [],
    history: {
      undo: () => {
        if (history.past.length === 0) return;
        const previous = history.past[history.past.length - 1];
        setHistory(h => ({ past: h.past.slice(0, -1), future: [data, ...h.future] }));
        setData(previous);
      },
      redo: () => {
        if (history.future.length === 0) return;
        const next = history.future[0];
        setHistory(h => ({ past: [...h.past, data], future: h.future.slice(1) }));
        setData(next);
      },
      canUndo: history.past.length > 0,
      canRedo: history.future.length > 0,
      jumpTo: (index) => {
        const target = history.past[index];
        if (target) {
          setHistory(h => ({
            past: h.past.slice(0, index),
            future: [...h.past.slice(index + 1), data, ...h.future],
          }));
          setData(target);
        }
      },
    },
    collaborators: [],
    resolveData: async () => {},
    resolveFields: async () => ({}),
    resolvePermissions: async () => ({}),
    ui: {
      ...ui,
      setLeftSidebarOpen: (open) => setUi(u => ({ ...u, leftSidebarOpen: open })),
      setRightSidebarOpen: (open) => setUi(u => ({ ...u, rightSidebarOpen: open })),
      setPreviewMode: (mode) => setUi(u => ({ ...u, previewMode: mode })),
      setViewport: (viewport) => setUi(u => ({ ...u, viewport })),
      setZoom: (zoom) => setUi(u => ({ ...u, zoom: Math.max(0.25, Math.min(2, zoom)) })),
    },
    permissions: {
      canEdit: permissions.canEdit ?? true,
      canPublish: permissions.canPublish ?? true,
      canDelete: permissions.canDelete ?? true,
      canCreate: permissions.canEdit ?? true,
      canManageSettings: permissions.canPublish ?? true,
    },
    insertComponent: () => {},
    duplicateComponent: () => {},
    deleteComponent: (id) => {
      setData(d => ({ ...d, content: d.content.filter(c => c.props.id !== id) }));
    },
    moveComponent: () => {},
    updateComponent: (id, props) => {
      setData(d => ({
        ...d,
        content: d.content.map(c => 
          c.props.id === id ? { ...c, props: { ...c.props, ...props } } : c
        ),
      }));
    },
    autoSave: {
      enabled: autoSave?.enabled ?? false,
      interval: autoSave?.interval ?? 5000,
      lastSaved: null,
      isSaving: false,
      error: null,
    },
    validation: {
      errors: [],
      warnings: [],
      validate: () => {
        const allErrors: ValidationError[] = [];
        for (const validator of validators) {
          const result = validator.validate(data);
          allErrors.push(...result.errors);
        }
        return allErrors.length === 0;
      },
    },
  };
  
  const autoSaveState = useAutoSave(
    data,
    autoSave?.saveFn ?? (async () => ({ success: true, version: 1 })),
    { interval: autoSave?.interval }
  );
  
  const defaultOverrides = createDefaultOverrides();
  const mergedOverrides = { ...defaultOverrides, ...overrides };
  
  return (
    <PuckContext.Provider value={contextValue}>
      <AIFieldProvider value={{ enabled: ai.enabled, model: ai.model ?? "gpt-4o" }}>
        <div className="millionx-puck-container" style={{ display: "flex", height: "100vh" }}>
          {ui.leftSidebarOpen && (
            <div className="millionx-left-sidebar" style={{ width: 250, borderRight: "1px solid #e5e5e5" }}>
              {plugins
                .filter(p => p.position === "left")
                .map(plugin => (
                  <div key={plugin.id} className="plugin-panel">
                    {plugin.render()}
                  </div>
                ))}
            </div>
          )}
          
          <div className="millionx-main" style={{ flex: 1, display: "flex", flexDirection: "column" }}>
            {mergedOverrides.header?.({
              children: null,
              actions: (
                <>
                  <button onClick={() => contextValue.history.undo()} disabled={!contextValue.history.canUndo}>
                    Undo
                  </button>
                  <button onClick={() => contextValue.history.redo()} disabled={!contextValue.history.canRedo}>
                    Redo
                  </button>
                  <button onClick={() => onPublish?.(data)}>Publish</button>
                </>
              ),
              title: header?.title,
              breadcrumbs: header?.breadcrumbs ?? [],
            })}
            
            <div className="millionx-toolbar">
              <select 
                value={ui.viewport.label} 
                onChange={(e) => {
                  const viewport = viewports.find(v => v.label === e.target.value);
                  if (viewport) contextValue.ui.setViewport(viewport);
                }}
              >
                {viewports.map(v => <option key={v.label} value={v.label}>{v.label}</option>)}
              </select>
              <button onClick={() => contextValue.ui.setZoom(ui.zoom - 0.1)}>-</button>
              <span>{Math.round(ui.zoom * 100)}%</span>
              <button onClick={() => contextValue.ui.setZoom(ui.zoom + 0.1)}>+</button>
              <button onClick={() => contextValue.ui.setPreviewMode("edit")}>Edit</button>
              <button onClick={() => contextValue.ui.setPreviewMode("preview")}>Preview</button>
              {preview.shareable && <button>Share Preview</button>}
            </div>
            
            <div className="millionx-canvas-container" style={{ flex: 1, overflow: "auto" }}>
              {mergedOverrides.canvas?.({
                children: (
                  <Puck
                    config={enhancedConfig}
                    data={data}
                    onChange={(newData) => {
                      setData(newData);
                      onChange?.(newData);
                    }}
                    overrides={mergedOverrides}
                    iframe={{ enabled: true }}
                  />
                ),
                viewport: ui.viewport,
                zoom: ui.zoom,
              })}
            </div>
            
            <div className="millionx-status-bar">
              <span>
                {autoSaveState.status === "saving" && "Saving..."}
                {autoSaveState.status === "saved" && `Saved ${autoSaveState.lastSaved?.toLocaleTimeString()}`}
                {autoSaveState.status === "error" && "Save failed"}
              </span>
              <span>{data.content.length} components</span>
            </div>
          </div>
          
          {ui.rightSidebarOpen && (
            <div className="millionx-right-sidebar" style={{ width: 300, borderLeft: "1px solid #e5e5e5" }}>
              {plugins
                .filter(p => p.position === "right")
                .map(plugin => (
                  <div key={plugin.id} className="plugin-panel">
                    {plugin.render()}
                  </div>
                ))}
            </div>
          )}
        </div>
      </AIFieldProvider>
    </PuckContext.Provider>
  );
}

// =============================================================================
// 10. DROPZONE & LAYOUT COMPONENTS
// =============================================================================

interface DropZoneProps {
  zone: string;
  allow?: string[];
  disallow?: string[];
  className?: string;
  style?: React.CSSProperties;
  minEmptyHeight?: number | string;
  collisionAxis?: "dynamic" | "x" | "y";
}

function DropZone(props: DropZoneProps) {
  return <PuckDropZone {...props} />;
}

interface SlotProps {
  name: string;
  children?: ReactNode;
  allow?: string[];
  disallow?: string[];
}

function Slot({ name, children, allow, disallow }: SlotProps) {
  const { data } = usePuck();
  const zoneContent = data.zones?.[name] ?? [];
  
  return (
    <div className="millionx-slot" data-slot-name={name}>
      <DropZone zone={name} allow={allow} disallow={disallow} />
      {children}
    </div>
  );
}

function Layout({ 
  children,
  header,
  footer,
  sidebar,
}: { 
  children: ReactNode;
  header?: ReactNode;
  footer?: ReactNode;
  sidebar?: ReactNode;
}) {
  return (
    <div className="millionx-layout">
      {header && <header className="layout-header">{header}</header>}
      <div className="layout-body">
        {sidebar && <aside className="layout-sidebar">{sidebar}</aside>}
        <main className="layout-main">{children}</main>
      </div>
      {footer && <footer className="layout-footer">{footer}</footer>}
    </div>
  );
}

// =============================================================================
// 11. SERVER RENDERER
// =============================================================================

interface ServerRendererProps {
  config: Config;
  data: Data;
  metadata?: Record<string, any>;
  resolveData?: boolean;
}

async function ServerRenderer({ 
  config, 
  data, 
  metadata,
  resolveData = true,
}: ServerRendererProps) {
  let resolvedData = data;
  
  if (resolveData) {
    const resolvedContent = await Promise.all(
      data.content.map(async (component) => {
        const componentConfig = config.components[component.type];
        if (componentConfig?.resolveData) {
          const resolved = await componentConfig.resolveData(component, {
            changed: {},
            lastData: null,
            trigger: "load",
            metadata: metadata ?? {},
          });
          return { ...component, props: { ...component.props, ...resolved.props } };
        }
        return component;
      })
    );
    resolvedData = { ...data, content: resolvedContent };
  }
  
  return <PuckRender config={config} data={resolvedData} metadata={metadata} />;
}

// =============================================================================
// 12. PREVIEW MODE
// =============================================================================

function createPreviewUrl(pageId: string, version?: number): string {
  const base = typeof window !== "undefined" ? window.location.origin : "";
  const params = version ? `?v=${version}` : "";
  return `${base}/preview/${pageId}${params}`;
}

function PreviewMode({ 
  config, 
  data, 
  expiresAt,
}: { 
  config: Config; 
  data: Data; 
  expiresAt?: Date;
}) {
  return (
    <div className="millionx-preview">
      <div className="preview-banner">
        <span>Preview Mode</span>
        {expiresAt && <span>Expires: {expiresAt.toLocaleString()}</span>}
        <button onClick={() => window.close()}>Close</button>
      </div>
      <PuckRender config={config} data={data} />
    </div>
  );
}

