# ============================================================
# Environment Variables — chrispropmanagment
# Copy to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# ── Supabase (required) ────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Guesty (required for booking blocks) ──────────────────────────────────
GUESTY_CLIENT_ID=your-guesty-client-id
GUESTY_CLIENT_SECRET=your-guesty-client-secret
NEXT_PUBLIC_GUESTY_ACCOUNT_ID=your-guesty-account-id

# ── App ─────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Chris Property Management

# ── Optional: Google Maps (for property detail map) ────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# ── Optional: Analytics ───────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_POSTHOG_KEY=
