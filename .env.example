# ============================================================
# Christiano Property Management — Environment Variables
# Copy to .env.local and fill in all values marked REQUIRED
# ============================================================

# ── Supabase ────────────────────────────────────────────────
# REQUIRED: Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# REQUIRED: Supabase anon/publishable key (safe for client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# REQUIRED (server only): Supabase service role key — NEVER expose to client
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Guesty ──────────────────────────────────────────────────
# REQUIRED: Guesty OAuth2 client credentials
# Generate at: https://app.guesty.com/integrations/api
GUESTY_CLIENT_ID=your-guesty-client-id
GUESTY_CLIENT_SECRET=your-guesty-client-secret

# ── Site ────────────────────────────────────────────────────
# Production URL used for sitemap, robots.txt, OG metadata
NEXT_PUBLIC_SITE_URL=https://chrispropmanagment.vercel.app

# ── Optional ────────────────────────────────────────────────
# Uncomment to enable bundle analyzer: ANALYZE=true
# ANALYZE=false
