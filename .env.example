# ============================================================
# ChrisPropManagement — Environment Variables Reference
# Copy to .env.local for development.
# Set ALL variables in Vercel Dashboard → Settings → Environment Variables for production.
# ============================================================

# ── Next.js ──────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://chrispropmanagment.vercel.app
NEXT_PUBLIC_APP_NAME="Chris Property Management"

# ── Supabase ─────────────────────────────────────────────────
# Project: supabase-citrine-saddle (mohpkakmpagvbqsehwhp) — ACTIVE_HEALTHY
# Dashboard: https://supabase.com/dashboard/project/mohpkakmpagvbqsehwhp
NEXT_PUBLIC_SUPABASE_URL=https://mohpkakmpagvbqsehwhp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im1vaHBrYWttcGFndmJxc2Vod2hwIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzUwNzQ5MDQsImV4cCI6MjA5MDY1MDkwNH0.-T-bnWnIRcPIS2xs20AOB7wsBaN64Po_CiXobBSDAi0
# SUPABASE_SERVICE_ROLE_KEY — get from Supabase Dashboard → Settings → API → service_role (SECRET — never commit)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# DB direct connection (for Drizzle/Prisma migrations only — NOT for app queries)
# Get from: Supabase Dashboard → Settings → Database → Connection String
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.mohpkakmpagvbqsehwhp.supabase.co:5432/postgres

# ── Upstash Redis ─────────────────────────────────────────────
# Required for Guesty GBE OAuth token caching (serverless-safe)
# From: https://console.upstash.com → Redis → REST API
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# ── Upstash QStash ────────────────────────────────────────────
# From: https://console.upstash.com → QStash → API Keys
QSTASH_TOKEN=your-qstash-token
QSTASH_CURRENT_SIGNING_KEY=sig_your_current_key
QSTASH_NEXT_SIGNING_KEY=sig_your_next_key

# ── Guesty Booking Engine API (GBE) ──────────────────────────
# ONLY these are used for booking.guesty.com flows
# From: https://app.guesty.com → Settings → Booking Engine → API Credentials
GUESTY_CLIENT_ID=your-guesty-client-id
GUESTY_CLIENT_SECRET=your-guesty-client-secret
GUESTY_BOOKING_API_URL=https://booking.guesty.com
NEXT_PUBLIC_GUESTY_ACCOUNT_ID=your-guesty-account-id

# ── Guesty Open API (Management — NOT for booking) ───────────
# Only used by /api/guesty/sync cron for listing data sync
GUESTY_API_URL=https://open-api.guesty.com

# ── Guesty Webhook ────────────────────────────────────────────
# Register URL in Guesty: Settings → Webhooks → https://chrispropmanagment.vercel.app/api/guesty/webhook
GUESTY_WEBHOOK_SECRET=your-guesty-webhook-secret

# ── Vercel Cron Auth ──────────────────────────────────────────
# Generate: openssl rand -hex 32
CRON_SECRET=your-cron-secret-hex-32

# ── NextAuth ──────────────────────────────────────────────────
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=https://chrispropmanagment.vercel.app

# ── AI (Puck AI Panel) ────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key
# Alternatives (uncomment one):
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=
