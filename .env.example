# ─────────────────────────────────────────────────────────────────────────────
# Christiano Property Management — Environment Variables Template
# Copy this file to .env.local and fill in real values.
# NEVER commit .env or .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── NextAuth ─────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=your-nextauth-secret-32-chars-min
NEXTAUTH_URL=http://localhost:3000

# ── Guesty Open API (admin/management — reservations, tasks, conversations) ──
# Get from: Guesty Dashboard → Integrations → Open API → Create App
GUESTY_CLIENT_ID=your-guesty-open-api-client-id
GUESTY_CLIENT_SECRET=your-guesty-open-api-client-secret

# ── Guesty Booking Engine API (guest-facing — listings, quotes, bookings) ────
# SEPARATE credentials from Open API above — different app, different scopes.
# Get from: Guesty Dashboard → Integrations → Booking Engine → Create API Instance
# Auth scope used: booking_engine:api
# Token URL: https://booking.guesty.com/oauth2/token
# API Base:  https://booking-api.guesty.com
GUESTY_BOOKING_CLIENT_ID=your-booking-engine-client-id
GUESTY_BOOKING_CLIENT_SECRET=your-booking-engine-client-secret

# ── Guesty Webhook (inbound events — HMAC-SHA256 verification) ───────────────
# This is a secret YOU define and configure in Guesty Dashboard → Webhooks.
# Generate with: openssl rand -hex 32
# Register webhook URL: https://your-domain.com/api/guesty/webhook
GUESTY_WEBHOOK_SECRET=your-guesty-webhook-hmac-secret

# ── Upstash Redis ────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# ── Upstash QStash ───────────────────────────────────────────────────────────
QSTASH_TOKEN=your-qstash-token
QSTASH_CURRENT_SIGNING_KEY=your-current-signing-key
QSTASH_NEXT_SIGNING_KEY=your-next-signing-key

# ── OpenAI (AI SDK) ──────────────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── MCP Server ───────────────────────────────────────────────────────────────
MCP_BASE_URL=http://localhost:3001
MCP_API_KEY=your-mcp-api-key

# ── Turbo Remote Cache (optional) ────────────────────────────────────────────
# Configure for faster CI builds: https://turbo.build/repo/docs/core-concepts/remote-caching
TURBO_TOKEN=
TURBO_TEAM=
