# ============================================================
# ChrisPropManagement — Environment Variables Reference
# Copy to .env.local for development. Set all in Vercel Dashboard for production.
# ============================================================

# ── Next.js ──────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://chrispropmanagment.vercel.app
NEXT_PUBLIC_APP_NAME="Chris Property Management"

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Upstash Redis ─────────────────────────────────────────────
# From: https://console.upstash.com → Redis → REST API
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# ── Upstash QStash ────────────────────────────────────────────
# From: https://console.upstash.com → QStash → API Keys
QSTASH_TOKEN=your-qstash-token
QSTASH_CURRENT_SIGNING_KEY=sig_your_current_key
QSTASH_NEXT_SIGNING_KEY=sig_your_next_key

# ── Guesty Open API (Management API) ─────────────────────────
# From: https://app.guesty.com → Settings → API Credentials
GUESTY_CLIENT_ID=your-guesty-client-id
GUESTY_CLIENT_SECRET=your-guesty-client-secret
GUESTY_API_URL=https://open-api.guesty.com

# ── Guesty Booking Engine API (GBE) ──────────────────────────
# From: https://app.guesty.com → Settings → Booking Engine
NEXT_PUBLIC_GUESTY_ACCOUNT_ID=your-guesty-account-id
GUESTY_BOOKING_API_URL=https://booking.guesty.com

# ── Guesty Webhook ────────────────────────────────────────────
# Set in Guesty dashboard → Settings → Webhooks
# Register URL: https://{NEXT_PUBLIC_SITE_URL}/api/guesty/webhook
GUESTY_WEBHOOK_SECRET=your-guesty-webhook-secret

# ── Vercel Cron Auth ──────────────────────────────────────────
# Set in Vercel Dashboard → Project Settings → Environment Variables
# Generate: openssl rand -hex 32
CRON_SECRET=your-cron-secret-hex-32

# ── NextAuth ──────────────────────────────────────────────────
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=https://chrispropmanagment.vercel.app

# ── AI (Puck AI Panel) ────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key
# or use local/other provider:
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=

# ── Database (Drizzle / Prisma) ───────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname
