# ─────────────────────────────────────────────────────────────────────────────
# Christiano Property Management — Environment Variables
# Copy to .env.local — NEVER commit .env.local
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (browser-safe) ───────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# ── Supabase Edge Function secrets (set in Supabase Dashboard → Secrets) ─────
# These are server-side only. Do NOT prefix with VITE_.

# AI: provide ONE of the following (OpenAI preferred, Gemini as fallback)
# OPENAI_API_KEY=sk-...          GPT-4o-mini powers cms-ai-enhance + cms-ai-agent
# GEMINI_API_KEY=...             Gemini 1.5 Flash — fallback AI provider

# Image search (optional — powers listing image fallbacks)
# PEXELS_API_KEY=...             Free at pexels.com/api

# Guesty property sync
# GUESTY_CLIENT_ID=...
# GUESTY_CLIENT_SECRET=...

# Deploy to Vercel (optional — for future 1-click deploy feature)
# VERCEL_DEPLOY_TOKEN=...
# VERCEL_TEAM_ID=...
# OPENPAGE_DEPLOY_KEY=...        Secret key for deploy endpoint auth (generate: openssl rand -hex 32)
# OPENPAGE_ALLOWED_ORIGINS=https://christiano.mt,https://www.christiano.mt
