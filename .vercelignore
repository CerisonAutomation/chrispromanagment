# ============================================================
# .vercelignore — Vercel deployment exclusions
# Prevents Vercel from scanning nested package.json files
# that trigger false monorepo detection and silent deploy failures
# ============================================================

# Nested MCP tool (has own package.json — NOT part of Next.js build)
puck-builder-mcp/

# IDE config
.idea/

# Dev/agent artefacts committed by mistake
skills/
docs/
scripts/

# Large JSON data files (not needed at build time)
21st-dev-all-components.json
21st-dev-components.json
21st-dev-magicui.json
search-21st-categories.json
search-21st-magicui.json
search-21st-usage.json
search-21st.json

# Markdown docs
AGENT_PROMPT.md
AI_MCP_INTEGRATION.md
ARCHITECTURE.md
BUILD_CHECKLIST.md
CANONICAL_CONSOLIDATION_REPORT.md
CODEBASE_AUDIT.md
COMPLETE_EXTRACTION.md
DEPLOYMENT_GUIDE.md
IMPROVEMENTS.md
MILLION_X_PUCK_AUDIT_COMPLETE.md
OMNISCAN_SUMMARY.md
PRISMA_FIX.md
PUCK_AI_SETUP.md
QUICK_START.md
UNIFIED_ARCHITECTURE.md
UNIFIED_SUMMARY.md
worklog.md
worklog-task-9.md
