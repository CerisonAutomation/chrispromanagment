generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// =============================================================================
// USER & AUTHENTICATION MODELS
// =============================================================================

enum UserRole {
  ADMIN
  EDITOR
  VIEWER
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  role          UserRole  @default(VIEWER)
  passwordHash  String?
  avatarUrl     String?
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  
  // Permissions
  canPublish    Boolean   @default(false)
  canDelete     Boolean   @default(false)
  canManageUsers Boolean  @default(false)
  canViewAnalytics Boolean @default(true)
  
  // Relations
  auditLogs     AuditLog[]
  pageVersions  PageVersion[]
  pageEdits     PageEdit[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([email])
  @@index([role])
}

model Session {
  id          String   @id @default(cuid())
  userId      String
  token       String   @unique
  expiresAt   DateTime
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  
  @@index([token])
  @@index([userId])
}

// =============================================================================
// CMS PAGE MODELS
// =============================================================================

enum PageStatus {
  DRAFT
  REVIEW
  APPROVED
  PUBLISHED
  SCHEDULED
  ARCHIVED
}

enum WorkflowState {
  DRAFT
  IN_REVIEW
  APPROVED
  PUBLISHED
}

model CmsPage {
  id            String    @id @default(cuid())
  slug          String    @unique
  title         String
  
  // Content separation
  draftData     String?
  publishedData String?
  
  // Workflow
  workflowState WorkflowState @default(DRAFT)
  assignedTo    String?
  reviewedBy    String?
  reviewedAt    DateTime?
  reviewNotes   String?
  
  // Metadata
  metaTitle       String?
  metaDescription String?
  metaKeywords    String    @default("[]")
  ogTitle         String?
  ogDescription   String?
  ogImage         String?
  canonicalUrl    String?
  noIndex         Boolean   @default(false)
  structuredData  String?
  
  // Localization
  locale         String     @default("en")
  translations   String     @default("{}") // JSON: { "en": {...}, "mt": {...}, "it": {...} }
  
  // State management
  status          PageStatus @default(DRAFT)
  publishedAt     DateTime?
  scheduledFor    DateTime?
  
  // Timestamps
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  
  // Relations
  versions    PageVersion[]
  audits      AuditLog[]
  edits       PageEdit[]
  abTests     ABTest[]
  webhooks    WebhookEvent[]
  calendarEvents ContentCalendar[]
  
  // Cache
  cacheTag    String    @default("")
  
  @@index([status, updatedAt])
  @@index([slug, status])
  @@index([workflowState])
  @@index([scheduledFor])
  @@index([locale])
}

model PageVersion {
  id          String   @id @default(cuid())
  pageId      String
  
  data        String
  diffFrom    String?
  baseVersion String?
  
  message     String?
  authorId    String?
  authorName  String?
  
  blocksAdded     Int    @default(0)
  blocksRemoved   Int    @default(0)
  blocksModified  Int    @default(0)
  
  // Diff storage
  diffData    String?  // JSON diff for efficient storage
  
  createdAt   DateTime @default(now())
  
  page CmsPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  author User?  @relation(fields: [authorId], references: [id])
  
  @@index([pageId, createdAt])
  @@index([pageId, authorId])
}

model PageEdit {
  id          String   @id @default(cuid())
  pageId      String
  
  type        String
  blockId     String?
  blockType   String?
  
  before      String?
  after       String?
  
  authorId    String?
  authorName  String?
  sessionId   String?
  
  createdAt   DateTime @default(now())
  
  page CmsPage @relation(fields: [pageId], references: [id], onDelete: Cascade)
  author User?  @relation(fields: [authorId], references: [id])
  
  @@index([pageId, createdAt])
  @@index([pageId, blockId])
}

// =============================================================================
// AUDIT LOGGING
// =============================================================================

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  PUBLISH
  UNPUBLISH
  SCHEDULE
  APPROVE
  REJECT
  LOGIN
  LOGOUT
  PERMISSION_CHANGE
  WEBHOOK_TRIGGERED
  AB_TEST_START
  AB_TEST_END
  AB_TEST_WINNER
  ASSET_UPLOAD
  ASSET_DELETE
  VERSION_RESTORE
  LOCALE_CHANGE
}

model AuditLog {
  id          String   @id @default(cuid())
  pageId      String?
  
  action      AuditAction
  details     String?
  
  userId      String?
  userName    String?
  ipAddress   String?
  userAgent   String?
  
  // Additional context
  resourceType String?
  resourceId   String?
  previousState String?
  newState     String?
  
  // Severity
  severity    String   @default("info") // info, warning, error, critical
  
  createdAt   DateTime @default(now())
  
  page CmsPage? @relation(fields: [pageId], references: [id], onDelete: SetNull)
  user User?    @relation(fields: [userId], references: [id])
  
  @@index([pageId, createdAt])
  @@index([action, createdAt])
  @@index([userId, createdAt])
  @@index([severity, createdAt])
  @@index([resourceType, resourceId])
}

// =============================================================================
// A/B TESTING
// =============================================================================

enum ABTestStatus {
  DRAFT
  RUNNING
  PAUSED
  COMPLETED
}

enum ABTestWinner {
  A
  B
  NONE
}

model ABTest {
  id            String   @id @default(cuid())
  pageId        String
  name          String
  description   String?
  
  // Variants
  variantAData  String   // JSON content for variant A
  variantBData  String   // JSON content for variant B
  
  // Traffic split
  trafficSplit  Int      @default(50) // Percentage to variant B
  
  // Goals
  primaryGoal   String   @default("conversions") // conversions, engagement, time_on_page
  successMetric String?  // Custom success metric
  
  // Results
  variantAConversions Int @default(0)
  variantBConversions Int @default(0)
  variantAVisitors    Int @default(0)
  variantBVisitors    Int @default(0)
  
  // Statistical significance
  confidenceLevel Float   @default(0.0)
  pValue          Float   @default(1.0)
  
  // Status
  status         ABTestStatus @default(DRAFT)
  winner         ABTestWinner @default(NONE)
  
  startedAt      DateTime?
  endedAt        DateTime?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  page CmsPage   @relation(fields: [pageId], references: [id], onDelete: Cascade)
  
  @@index([pageId, status])
  @@index([status, startedAt])
}

// =============================================================================
// CONTENT CALENDAR
// =============================================================================

enum CalendarEventType {
  PUBLISH
  REVIEW
  MEETING
  CAMPAIGN
  SEASONAL
  CUSTOM
}

model ContentCalendar {
  id          String   @id @default(cuid())
  pageId      String?
  
  title       String
  description String?
  
  eventType   CalendarEventType @default(CUSTOM)
  
  startDate   DateTime
  endDate     DateTime?
  
  status      String    @default("scheduled") // scheduled, completed, cancelled
  
  // Recurrence
  recurrence  String?   // JSON: { pattern: "weekly", days: ["monday", "wednesday"] }
  
  // Reminders
  reminders   String    @default("[]") // JSON array of reminder times
  
  // Assignee
  assignedTo  String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  page CmsPage? @relation(fields: [pageId], references: [id], onDelete: SetNull)
  
  @@index([startDate, endDate])
  @@index([eventType, status])
}

// =============================================================================
// WEBHOOKS
// =============================================================================

enum WebhookEvent {
  PAGE_PUBLISHED
  PAGE_UPDATED
  PAGE_DELETED
  PAGE_SCHEDULED
  ASSET_UPLOADED
  USER_CREATED
  USER_UPDATED
  AB_TEST_STARTED
  AB_TEST_COMPLETED
  CONTENT_REVIEW_REQUESTED
  CONTENT_APPROVED
}

model Webhook {
  id            String   @id @default(cuid())
  
  name          String
  url           String
  secret        String?
  
  events        String   // JSON array of WebhookEvent values
  isActive      Boolean  @default(true)
  
  // Headers for authentication
  headers       String?  // JSON: { "Authorization": "Bearer ..." }
  
  // Retry configuration
  retryCount    Int      @default(3)
  retryDelay    Int      @default(1000) // ms
  
  // Stats
  successCount  Int      @default(0)
  failureCount Int      @default(0)
  lastTriggered DateTime?
  lastSuccess   DateTime?
  lastFailure   DateTime?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  events_list WebhookEvent[]
  
  @@index([isActive])
}

model WebhookEvent {
  id          String   @id @default(cuid())
  webhookId   String
  
  event       WebhookEvent
  payload     String   // JSON payload sent
  
  status      String   @default("pending") // pending, success, failed
  statusCode  Int?
  response    String?
  error       String?
  
  attempts    Int      @default(0)
  
  createdAt   DateTime @default(now())
  sentAt      DateTime?
  
  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  
  @@index([webhookId, status])
  @@index([createdAt])
}

// =============================================================================
// ASSET MANAGEMENT WITH OPTIMIZATION
// =============================================================================

model Asset {
  id          String   @id @default(cuid())
  
  filename    String
  originalName String
  mimeType    String
  size        Int
  
  // Storage
  url         String
  thumbnailUrl String?
  
  // Optimized variants
  variants    String?  // JSON: { "320": "url", "640": "url", "1024": "url", "2048": "url" }
  optimizedUrl String?
  
  // Image metadata
  width       Int?
  height      Int?
  altText     String?
  focalPointX Float?
  focalPointY Float?
  
  // Video specific
  duration    Int?     // seconds
  videoThumbnail String?
  
  // Organization
  folder      String   @default("/")
  tags        String   @default("[]")
  
  // Usage tracking
  usageCount  Int      @default(0)
  usedInPages String   @default("[]")
  
  // Upload info
  uploadedBy  String?
  
  // CDN info
  cdnProvider String?
  cdnUrl      String?
  
  // Processing status
  processingStatus String @default("pending") // pending, processing, complete, failed
  processingError String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([folder, createdAt])
  @@index([mimeType])
  @@index([processingStatus])
}

// =============================================================================
// CDN CONFIGURATION
// =============================================================================

model CDNConfig {
  id            String   @id @default(cuid())
  
  provider      String   // cloudflare, vercel, aws, custom
  isActive      Boolean  @default(true)
  
  // Configuration
  config        String   // JSON configuration
  
  // Custom domains
  customDomain  String?
  cdnZone       String?
  
  // Cache settings
  cacheTTL      Int      @default(31536000) // seconds
  purgeOnUpdate Boolean  @default(true)
  
  // Stats
  hitCount      Int      @default(0)
  missCount     Int      @default(0)
  bandwidth     Int      @default(0) // bytes
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// =============================================================================
// LIVE PREVIEW
// =============================================================================

model PreviewLink {
  id          String   @id @default(cuid())
  
  pageSlug    String
  token       String   @unique
  
  // Access
  isActive    Boolean  @default(true)
  maxViews    Int?     // null = unlimited
  viewCount   Int      @default(0)
  
  expiresAt   DateTime?
  
  // Meta
  createdBy   String?
  createdAt   DateTime @default(now())
  lastAccessed DateTime?
  
  @@index([token])
  @@index([pageSlug])
}

// =============================================================================
// EXISTING PROPERTY MODELS (Unchanged)
// =============================================================================

model Property {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  type          String   @default("apartment")
  description   String
  location      String
  city          String   @default("Valletta")
  address       String   @default("")
  latitude      String   @default("35.8992")
  longitude     String   @default("14.5140")
  bedrooms      Int      @default(2)
  bathrooms     Int      @default(2)
  maxGuests     Int      @default(4)
  basePrice     Float    @default(150)
  currency      String   @default("EUR")
  cleaningFee   Float    @default(50)
  minStay       Int      @default(2)
  maxStay       Int      @default(30)
  checkInTime   String   @default("15:00")
  checkOutTime  String   @default("11:00")
  amenities     String   @default("[]")
  images        String   @default("[]")
  rating        Float    @default(4.9)
  reviewCount   Int      @default(0)
  featured      Boolean  @default(true)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  bookings Booking[]
}

model Booking {
  id            String   @id @default(cuid())
  confirmationCode String @unique
  propertyId    String
  propertyName  String   @default("")
  guestName     String
  guestEmail    String
  guestPhone    String
  guestAddress  String   @default("")
  guestCity     String   @default("")
  guestCountry  String   @default("")
  checkIn       String
  checkOut      String
  nights        Int      @default(1)
  guests        Int      @default(1)
  basePrice     Float    @default(0)
  cleaningFee   Float    @default(0)
  serviceFee    Float    @default(0)
  totalPrice    Float    @default(0)
  currency      String   @default("EUR")
  status        String   @default("pending")
  source        String   @default("direct")
  specialRequests String @default("")
  notes         String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id])

  @@index([propertyId, status])
  @@index([propertyId, checkIn, checkOut])
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}
